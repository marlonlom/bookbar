<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="Help">
        <Preference
            app:iconSpaceReserved="false"
            app:key="bookbar_setting_feedback"
            app:summary="Report technical issues or suggest new features"
            app:title="Send feedback">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://itbook.store/feedback" />
        </Preference>
        <Preference
            app:iconSpaceReserved="false"
            app:key="bookbar_setting_privacy_policy"
            app:title="Privacy policy">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://itbook.store/privacypolicy" />
        </Preference>
    </PreferenceCategory>

    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="About">
        <Preference
            app:iconSpaceReserved="false"
            app:key="bookbar_setting_version"
            app:summary="1.0.0"
            app:title="Version" />
    </PreferenceCategory>

</PreferenceScreen>