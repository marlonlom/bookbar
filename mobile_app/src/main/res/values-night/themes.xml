<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Bookbar" parent="Base.Theme.Bookbar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_granny_apple</item>
        <item name="colorPrimaryVariant">@color/brand_ziggurat</item>
        <item name="colorSecondary">@color/brand_old_lace</item>
        <item name="colorSecondaryVariant">@color/brand_old_lace</item>
        <item name="android:colorBackground">@color/brand_black</item>
        <item name="colorSurface">@color/brand_cod_gray</item>
        <item name="colorError">@color/brand_charm</item>
        <item name="colorOnPrimary">@color/brand_black</item>
        <item name="colorOnSecondary">@color/brand_black</item>
        <item name="colorOnBackground">@color/brand_white</item>
        <item name="colorOnSurface">@color/brand_white</item>
        <item name="colorOnError">@color/brand_black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">true</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">true</item>
        <!-- Customize your theme here. -->
    </style>
</resources>